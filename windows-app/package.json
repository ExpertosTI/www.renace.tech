{
  "name": "renace-windows-app",
  "version": "1.0.0",
  "description": "RENACE.TECH - Aplicación de escritorio para Windows",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "dist": "electron-builder --win --publish=never",
    "pack": "electron-builder --dir"
  },
  "author": "RENACE.TECH",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "tech.renace.app",
    "productName": "RENACE App",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/",
      "assets/",
      "node_modules/"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico",
      "publisherName": "RENACE.TECH"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "RENACE App",
      "include": "installer.nsh"
    },
    "protocols": [
      {
        "name": "RENACE Protocol",
        "schemes": ["renace"]
      }
    ]
  },
  "dependencies": {
    "node-fetch": "^2.7.0"
  }
}
