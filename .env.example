# Database
POSTGRES_USER=renace_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=renace_db
DATABASE_URL=postgresql://renace_user:change_me_in_production@db:5432/renace_db

# App
NEXT_PUBLIC_BASE_URL=https://renace.tech
APP_HOST=renace.tech
ADMIN_ACCESS_PASSWORD=change_me_admin_password_32chars
ADMIN_SESSION_SECRET=change_me_random_string_32chars
PARTICIPANT_SESSION_SECRET=change_me_another_random_string

# SMTP (Email) — Hostinger: SMTP_USER y SMTP_FROM = info@renace.tech
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=0
SMTP_USER=info@renace.tech
SMTP_PASSWORD=your-mailbox-password
SMTP_FROM=RENACE.TECH <info@renace.tech>
MAIL_REPLY_TO=info@renace.tech

# WhatsApp — Evolution API (notificador global)
EVOLUTION_API_URL=https://evoapi.renace.tech
EVOLUTION_API_KEY=your-evolution-global-api-key
EVOLUTION_INSTANCE=RENACE.TECH
WHATSAPP_SENDER_NUMBER=18093487921
WHATSAPP_NOTIFY_NUMBERS=18494577463,18099152622
NOTIFY_API_KEY=change_me_notify_key_for_other_apps

# Google OAuth (Portal de Clientes)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
PORTAL_ENCRYPTION_KEY=random-string-min-16-chars-for-aes256

# Odoo Integration
ODOO_URL=http://your-odoo-server:7015
ODOO_LONGPOLL_URL=http://your-odoo-server:7018
ODOO_DB=your-odoo-database
ODOO_API_USER=your-odoo-user@example.com
ODOO_API_KEY=your-odoo-api-key
ODOO_DEFAULT_PARTNER=3

# Admin notification
ADMIN_EMAIL=admin@renace.tech

# Wedding Invitation (optional, only for wedding subproject)
WEDDING_ADMIN_KEY=change-this-to-a-strong-random-key
