<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit res.users form to add the RENACE SSO button -->
    <record id="view_users_form_renace_sso" model="ir.ui.view">
        <field name="name">res.users.form.renace.sso</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <!-- Add the button in the header/button box area -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_generate_renace_sso_link"
                        type="object"
                        string="Generar Acceso RENACE"
                        class="oe_stat_button"
                        icon="fa-external-link"
                        title="Genera un enlace de inicio de sesión automático para el portal de renace.tech"
                        groups="base.group_system"/>
            </xpath>

            <!-- Add RENACE portal status field in the user preferences tab -->
            <xpath expr="//page[@name='preferences']" position="inside">
                <separator string="Portal RENACE.TECH"/>
                <group>
                    <field name="renace_portal_active"
                           widget="boolean_toggle"
                           groups="base.group_system"/>
                    <field name="renace_portal_login"
                           invisible="not renace_portal_active"
                           groups="base.group_system"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
