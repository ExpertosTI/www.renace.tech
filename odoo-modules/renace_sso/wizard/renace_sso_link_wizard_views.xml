<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_renace_sso_link_wizard_form" model="ir.ui.view">
        <field name="name">renace.sso.link.wizard.form</field>
        <field name="model">renace.sso.link.wizard</field>
        <field name="arch" type="xml">
            <form string="Generar Enlace de Acceso — RENACE">

                <!-- Hidden fields needed for state management -->
                <field name="state" invisible="1"/>

                <!-- State: draft — Pending generation -->
                <div invisible="state != 'draft'">
                    <div class="alert alert-info mb-3" role="status">
                        <i class="fa fa-info-circle me-2"/>
                        <strong>¿Cómo funciona?</strong> Se generará un enlace único de acceso para
                        <strong><field name="odoo_login" nolabel="1" readonly="1" class="d-inline"/></strong>
                        que le permitirá iniciar sesión en Odoo directamente desde el portal de
                        <strong>renace.tech</strong> sin necesidad de contraseña.
                        El enlace expira en <strong>5 minutos</strong>.
                    </div>

                    <group>
                        <field name="user_id" readonly="1"/>
                        <field name="instance_name"
                               placeholder="Ej: ERP Producción — Mi Empresa"
                               help="Nombre descriptivo que se mostrará en el portal de renace.tech para identificar esta instancia."/>
                    </group>
                </div>

                <!-- State: done — Link generated successfully -->
                <div invisible="state != 'done'">
                    <div class="alert alert-success mb-3" role="status">
                        <i class="fa fa-check-circle me-2"/>
                        <strong>¡Enlace generado exitosamente!</strong>
                        Copia el enlace y compártelo con el usuario. Expira en <strong>5 minutos</strong>.
                    </div>

                    <group>
                        <field name="user_id" readonly="1"/>
                        <field name="odoo_login" readonly="1"/>
                    </group>

                    <separator string="Enlace de Acceso"/>
                    <div class="mb-2">
                        <field name="sso_link" readonly="1" widget="url"
                               style="font-size: 0.85rem; word-break: break-all;"/>
                    </div>
                    <div class="text-muted small mt-1">
                        <i class="fa fa-clock-o me-1"/>
                        Este enlace es de un solo uso y expira en 5 minutos.
                    </div>
                </div>

                <!-- State: error -->
                <div invisible="state != 'error'">
                    <div class="alert alert-danger mb-3" role="alert">
                        <i class="fa fa-exclamation-triangle me-2"/>
                        <strong>Error al generar el enlace</strong>
                        <p class="mb-0 mt-1"><field name="error_message" readonly="1" nolabel="1"/></p>
                    </div>
                    <div class="text-muted small">
                        <p>Posibles causas:</p>
                        <ul>
                            <li>El usuario no está registrado en el portal de renace.tech.</li>
                            <li>La clave de cifrado (<code>renace_sso.portal_encryption_key</code>) no está configurada.</li>
                            <li>No hay conectividad con <strong>renace.tech</strong>.</li>
                        </ul>
                    </div>
                </div>

                <footer>
                    <!-- Draft state buttons -->
                    <button name="action_generate_link"
                            type="object"
                            string="Generar Enlace"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <!-- Done state buttons -->
                    <button name="action_copy_done"
                            type="object"
                            string="Cerrar"
                            class="btn-primary"
                            invisible="state != 'done'"/>

                    <!-- Error state buttons -->
                    <button name="action_generate_link"
                            type="object"
                            string="Reintentar"
                            class="btn-warning"
                            invisible="state != 'error'"/>

                    <button string="Cancelar"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
