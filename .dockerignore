# Never ship secrets or local state to containers
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.keystore
client_secret*.json
credentials*.json
*service-account*.json
secrets/
**/secrets/

# Git history / VCS metadata
.git/
.gitignore
.gitattributes

# Dependencies — images install fresh
node_modules/
**/node_modules/
npm-debug.log*
yarn-error.log

# IDE / editor / AI agents
.idea/
.vscode/
.superpowers/
.windsurf/
.trae/
.claude/
_agents/

# OS clutter
.DS_Store
Thumbs.db

